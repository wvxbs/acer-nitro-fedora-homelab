# Copy to config/homelab.env and edit before running scripts/bootstrap.sh.

HOMELAB_HOSTNAME=nitro-homelab
ADMIN_USER=
SSH_AUTHORIZED_KEYS=

# Set to 1 if you want Tailscale installed.
INSTALL_TAILSCALE=1
TAILSCALE_AUTHKEY=
TAILSCALE_EXTRA_ARGS=--ssh

# Local storage root on the internal SSD.
STORAGE_ROOT=/srv/storage

# Rclone OneDrive settings for media servers. Prefer mount-on-demand over sync
# so the SSD only stores bounded VFS cache, not the whole library.
RCLONE_REMOTE_NAME=onedrive
ONEDRIVE_PATH=Vídeos/Filmes
ONEDRIVE_MOUNT_PATH=/srv/storage/media/onedrive
RCLONE_CONFIG_PATH=/home/wvxbs/.config/rclone/rclone.conf
RCLONE_CACHE_DIR=/srv/appdata/rclone/vfs-cache
RCLONE_VFS_CACHE_MAX_SIZE=40G
RCLONE_VFS_CACHE_MAX_AGE=12h
RCLONE_VFS_CACHE_MIN_FREE_SPACE=30G
RCLONE_BUFFER_SIZE=64M
RCLONE_USER=
RCLONE_BWLIMIT=

# Docker/service paths.
HOMELAB_ROOT=/opt/homelab
APPDATA_DIR=/srv/appdata
MEDIA_DIR=/srv/storage/media
PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# Optional AI stack.
INSTALL_AI=0
OLLAMA_MODELS_DIR=/srv/appdata/ollama

# Optional Linux users prepared for per-person Codex SSH delegation.
# Leave empty to skip. Example: CODEX_USERS="wvxbs mae pai"
CODEX_USERS=

# Optional DNS sinkhole. Start conservatively, test manually, then point clients/router to it.
DNS_BIND_IP=192.168.15.8
DNS_ADMIN_PORT=3001

# Optional limited OS user for family access through Cockpit.
FAMILY_USER=familia

# Optional local security panel and physical TTY failed-login capture.
SECURITY_DATA_DIR=/srv/appdata/security
SECURITY_CAPTURE_SECONDS=8
SECURITY_RETENTION_DAYS=7
