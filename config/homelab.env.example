# Copy to config/homelab.env and edit before running scripts/bootstrap.sh.

HOMELAB_HOSTNAME=nitro-pve
ADMIN_USER=root
SSH_AUTHORIZED_KEYS=
TZ=America/Sao_Paulo

# Proxmox network. The CT defaults to DHCP on vmbr0.
PROXMOX_BRIDGE=vmbr0
MEDIA_CT_ID=120
MEDIA_CT_HOSTNAME=media
MEDIA_CT_MEMORY=4096
MEDIA_CT_SWAP=512
MEDIA_CT_CORES=2
MEDIA_CT_ROOTFS=local-lvm:24
MEDIA_CT_STORAGE=local
MEDIA_CT_UNPRIVILEGED=0
MEDIA_CT_PASSWORD=
MEDIA_CT_IP=dhcp
DEBIAN_CT_RELEASE=12

# NVIDIA strategy: host driver + LXC device exposure.
INSTALL_NVIDIA=1
ENABLE_NVIDIA_LXC=1

# Tailscale on the Proxmox host.
INSTALL_TAILSCALE=1
TAILSCALE_AUTHKEY=
TAILSCALE_EXTRA_ARGS=--ssh

# External 5400 rpm disk. Leave UUID empty to skip fstab changes.
EXTERNAL_DISK_UUID=
EXTERNAL_DISK_FSTYPE=ext4
EXTERNAL_MOUNTPOINT=/srv/storage

# Host paths bind-mounted into the media CT.
APPDATA_DIR=/srv/appdata
MEDIA_DIR=/srv/storage/media
TRANSCODE_DIR=/srv/appdata/plex/transcode
ONEDRIVE_LOCAL_PATH=/srv/storage/incoming/onedrive

# Rclone pull-only settings inside the media CT.
RCLONE_REMOTE_NAME=onedrive
ONEDRIVE_PATH=Rips/DVD
RCLONE_USER=plex
RCLONE_SCHEDULE=*:0/30
RCLONE_BWLIMIT=

# Plex setup inside the media CT.
INSTALL_PLEX=1
PLEX_CLAIM=

# Optional: keep Compose bundle available for non-GPU workloads.
INSTALL_COMPOSE_BUNDLE=0
HOMELAB_ROOT=/opt/homelab
PUID=1000
PGID=1000
PLEX_ADVERTISE_IP=
INSTALL_AI=0
OLLAMA_MODELS_DIR=/srv/appdata/ollama
