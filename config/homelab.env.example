# Copy to config/homelab.env and edit before running scripts/bootstrap.sh.

HOMELAB_HOSTNAME=nitro-homelab
ADMIN_USER=
SSH_AUTHORIZED_KEYS=

# Set to 1 if you want Tailscale installed.
INSTALL_TAILSCALE=1
TAILSCALE_AUTHKEY=
TAILSCALE_EXTRA_ARGS=--ssh

# Local storage root on the internal SSD.
STORAGE_ROOT=/srv/storage

# Rclone OneDrive settings for media servers. Prefer mount-on-demand over sync
# so the SSD only stores bounded VFS cache, not the whole library.
RCLONE_REMOTE_NAME=onedrive
ONEDRIVE_PATH=Vídeos/Filmes
ONEDRIVE_MOUNT_PATH=/srv/storage/media/onedrive
RCLONE_CONFIG_PATH=/home/wvxbs/.config/rclone/rclone.conf
RCLONE_CACHE_DIR=/srv/appdata/rclone/vfs-cache
RCLONE_VFS_CACHE_MAX_SIZE=40G
RCLONE_VFS_CACHE_MAX_AGE=12h
RCLONE_VFS_CACHE_MIN_FREE_SPACE=30G
RCLONE_BUFFER_SIZE=64M
RCLONE_USER=
RCLONE_BWLIMIT=

# Docker/service paths.
HOMELAB_ROOT=/opt/homelab
APPDATA_DIR=/srv/appdata
MEDIA_DIR=/srv/storage/media
TRANSCODE_DIR=/srv/appdata/plex/transcode
PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# Optional browser terminal for emergency host administration.
# Keep this disabled unless needed. Proxy mode lets Caddy ask for browser
# credentials before opening the host shell.
TERMINAL_AUTH_MODE=proxy
TERMINAL_USERNAME=admin
TERMINAL_PASSWORD=
TERMINAL_PASSWORD_HASH=
TERMINAL_PORT=7681
TERMINAL_WORKDIR=/root
TERMINAL_SHELL=/bin/bash

# Optional AI stack.
INSTALL_AI=0
OLLAMA_MODELS_DIR=/srv/appdata/ollama
OPENWEBUI_ENABLE_SIGNUP=true
OPENWEBUI_BYPASS_MODEL_ACCESS_CONTROL=true
OPENWEBUI_DEFAULT_MODELS=qwen3-openclaw:latest
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_OLLAMA_API_KEY=ollama-local
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
OPENCLAW_DISABLE_BONJOUR=1

# Optional Minecraft Java + Bedrock LAN servers.
MINECRAFT_BIND_IP=0.0.0.0
MINECRAFT_JAVA_PORT=25565
MINECRAFT_BEDROCK_PORT=19132
MINECRAFT_JAVA_MEMORY=6G
MINECRAFT_JAVA_LEVEL_NAME=Nitro-Java
MINECRAFT_JAVA_MOTD="Nitro Java"
MINECRAFT_JAVA_DIFFICULTY=normal
MINECRAFT_JAVA_MAX_PLAYERS=10
MINECRAFT_JAVA_OPS=
MINECRAFT_JAVA_WHITELIST=
MINECRAFT_JAVA_ENABLE_WHITELIST=false
MINECRAFT_JAVA_ENFORCE_WHITELIST=false
MINECRAFT_JAVA_ENABLE_RCON=false
MINECRAFT_JAVA_RCON_PASSWORD=
MINECRAFT_BEDROCK_LEVEL_NAME=Nitro-Bedrock
MINECRAFT_BEDROCK_SERVER_NAME="Nitro Bedrock"
MINECRAFT_BEDROCK_GAMEMODE=survival
MINECRAFT_BEDROCK_DIFFICULTY=normal
MINECRAFT_BEDROCK_MAX_PLAYERS=10
MINECRAFT_BEDROCK_ALLOW_LIST=false
MINECRAFT_BACKUP_REMOTE_PATH="Documentos/Roms/Minecraft Worlds"
MINECRAFT_BACKUP_ONEDRIVE=1
MINECRAFT_BACKUP_TIMER=03:30
MINECRAFT_BACKUP_KEEP_LOCAL_DAYS=7

# Optional Linux users prepared for per-person Codex SSH delegation.
# Leave empty to skip. Example: CODEX_USERS="wvxbs mae pai"
CODEX_USERS=

# Optional DNS sinkhole. Start conservatively, test manually, then point clients/router to it.
DNS_BIND_IP=192.168.15.8
DNS_ADMIN_PORT=3001

# Optional no-login LAN file drop over SMB3.
# The share is temporary: old files are removed after FILE_DROP_TTL_HOURS, and
# the cleanup sidecar keeps it under FILE_DROP_MAX_SIZE by deleting oldest
# top-level entries first.
FILE_DROP_DIR=/srv/storage/drop
FILE_DROP_SHARE_NAME=drop
FILE_DROP_WORKGROUP=WORKGROUP
FILE_DROP_NETBIOS_NAME=NITRO-DROP
FILE_DROP_HOSTNAME=nitro-drop
FILE_DROP_GUEST_USER=filedrop
FILE_DROP_USERNAME=
FILE_DROP_PASSWORD=
FILE_DROP_TTL_HOURS=24
FILE_DROP_MAX_SIZE=100G
FILE_DROP_CLEANUP_INTERVAL_SECONDS=300

# Optional local security event/capture dashboard data path.
SECURITY_DATA_DIR=/srv/appdata/security

# Optional limited OS user for family access through Cockpit.
FAMILY_USER=familia

# Optional local security panel and physical TTY failed-login capture.
SECURITY_DATA_DIR=/srv/appdata/security
SECURITY_CAPTURE_SECONDS=8
SECURITY_RETENTION_DAYS=7
