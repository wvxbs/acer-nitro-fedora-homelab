# Copy to config/homelab.env and edit before running scripts/bootstrap.sh.

HOMELAB_HOSTNAME=nitro-homelab
ADMIN_USER=
SSH_AUTHORIZED_KEYS=

# Set to 1 if you want Tailscale installed.
INSTALL_TAILSCALE=1
TAILSCALE_AUTHKEY=
TAILSCALE_EXTRA_ARGS=--ssh

# External 5400 rpm disk. Leave empty to skip fstab changes.
EXTERNAL_DISK_UUID=
EXTERNAL_DISK_FSTYPE=ext4
EXTERNAL_MOUNTPOINT=/srv/storage

# Rclone pull-only settings.
RCLONE_REMOTE_NAME=onedrive
ONEDRIVE_PATH=Rips/DVD
ONEDRIVE_LOCAL_PATH=/srv/storage/incoming/onedrive
RCLONE_USER=
RCLONE_SCHEDULE=*:0/30
RCLONE_BWLIMIT=

# Docker/service paths.
HOMELAB_ROOT=/opt/homelab
APPDATA_DIR=/srv/appdata
MEDIA_DIR=/srv/storage/media
TRANSCODE_DIR=/srv/appdata/plex/transcode
PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# Plex claim token is optional and expires quickly. Prefer setting it only on first run.
PLEX_CLAIM=
PLEX_ADVERTISE_IP=

# Optional AI stack.
INSTALL_AI=0
OLLAMA_MODELS_DIR=/srv/appdata/ollama

# Optional DNS sinkhole. Start conservatively, test manually, then point clients/router to it.
DNS_BIND_IP=192.168.15.8
DNS_ADMIN_PORT=3001
