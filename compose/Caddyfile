{
  admin off
}

(local_tls) {
  tls internal
}

(cockpit_proxy) {
  reverse_proxy https://127.0.0.1:9090 {
    header_up Host cockpit.nitro.lan
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-For {remote_host}
    transport http {
      tls_insecure_skip_verify
    }
  }
}

(terminal_auth) {
  basic_auth {
    {$TERMINAL_USERNAME:admin} {$TERMINAL_PASSWORD_HASH}
  }
}

http://nitro.lan {
  handle /ca/root.crt {
    root * /data/caddy/pki/authorities/local
    rewrite * /root.crt
    file_server
  }

  redir https://nitro.lan{uri} 308
}

