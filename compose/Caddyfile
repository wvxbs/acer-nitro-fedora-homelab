(dashboard) {
  root * /srv/dashboard

  handle /health/caddy {
    respond "ok" 200
  }

  handle_path /health/cockpit {
    import cockpit_proxy
  }

  handle_path /health/adguard {
    rewrite * /login.html
    reverse_proxy http://127.0.0.1:3001 {
      header_up Host adguard.nitro.lan
    }
  }

  handle_path /health/telemetry {
    rewrite * /_stcore/health
    reverse_proxy http://127.0.0.1:8501
  }

  handle_path /health/performance {
    reverse_proxy http://127.0.0.1:9837
  }

  handle_path /health/jellyfin {
    rewrite * /System/Info/Public
    reverse_proxy http://127.0.0.1:8096
  }

  handle_path /health/openwebui {
    rewrite * /health
    reverse_proxy http://127.0.0.1:3000
  }

  handle_path /health/terminal {
    respond "ok" 200
  }

  handle_path /health/openclaw {
    rewrite * /healthz
    reverse_proxy http://127.0.0.1:18789
  }

  handle_path /health/ollama {
    rewrite * /api/tags
    reverse_proxy http://127.0.0.1:11434
  }

  handle_path /health/portainer {
    rewrite * /api/system/status
    reverse_proxy https://127.0.0.1:9443 {
      header_up Host {host}
      header_up X-Forwarded-Host {host}
      transport http {
        tls_insecure_skip_verify
      }
    }
  }

  handle_path /health/dozzle {
    reverse_proxy http://127.0.0.1:9999
  }

  handle_path /health/processes {
    reverse_proxy http://127.0.0.1:61208
  }

