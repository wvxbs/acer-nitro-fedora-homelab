{
  admin off
}

(local_tls) {
  tls internal
}

(cockpit_proxy) {
  reverse_proxy https://127.0.0.1:9090 {
    header_up Host cockpit.nitro.lan
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-For {remote_host}
    transport http {
      tls_insecure_skip_verify
    }
  }
}

http://nitro.lan {
  handle /ca/root.crt {
    root * /data/caddy/pki/authorities/local
    rewrite * /root.crt
    file_server
  }

  redir https://nitro.lan{uri} 308
}

http://adguard.nitro.lan,
http://cockpit.nitro.lan,
http://telemetry.nitro.lan,
http://jellyfin.nitro.lan,
http://openwebui.nitro.lan,
http://ollama.nitro.lan,
http://plex.nitro.lan,
http://portainer.nitro.lan,
http://dozzle.nitro.lan,
http://glances.nitro.lan,
http://gpu.nitro.lan {
  redir https://{host}{uri} 308
}

https://nitro.lan {
  import local_tls
  root * /srv/dashboard

  handle /ca/root.crt {
    root * /data/caddy/pki/authorities/local
    rewrite * /root.crt
    file_server
  }

  handle /health/caddy {
    respond "ok" 200
  }

  handle_path /health/cockpit {
    import cockpit_proxy
  }

  handle_path /health/adguard {
    rewrite * /login.html
    reverse_proxy http://127.0.0.1:3001 {
      header_up Host adguard.nitro.lan
    }
  }

  handle_path /health/telemetry {
    rewrite * /_stcore/health
    reverse_proxy http://127.0.0.1:8501
  }

  handle_path /health/jellyfin {
    rewrite * /System/Info/Public
    reverse_proxy http://127.0.0.1:8096
  }

  handle_path /health/openwebui {
    rewrite * /health
    reverse_proxy http://127.0.0.1:3000
  }

  handle_path /health/ollama {
    rewrite * /api/tags
    reverse_proxy http://127.0.0.1:11434
  }

  handle_path /health/plex {
    rewrite * /identity
    reverse_proxy http://127.0.0.1:32400
  }

  handle_path /health/portainer {
    rewrite * /api/status
    reverse_proxy https://127.0.0.1:9443 {
      transport http {
        tls_insecure_skip_verify
      }
    }
  }

  handle_path /health/dozzle {
    reverse_proxy http://127.0.0.1:9999
  }

  handle_path /health/glances {
    reverse_proxy http://127.0.0.1:61208
  }

  handle_path /health/gpu {
    reverse_proxy http://127.0.0.1:9836
  }

  file_server
}

https://cockpit.nitro.lan {
  import local_tls
  import cockpit_proxy
}

https://adguard.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:3001
}

https://telemetry.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:8501
}

https://jellyfin.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:8096
}

https://openwebui.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:3000
}

https://ollama.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:11434
}

https://plex.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:32400
}

https://portainer.nitro.lan {
  import local_tls
  reverse_proxy https://127.0.0.1:9443 {
    transport http {
      tls_insecure_skip_verify
    }
  }
}

https://dozzle.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:9999
}

https://glances.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:61208
}

https://gpu.nitro.lan {
  import local_tls
  reverse_proxy http://127.0.0.1:9836
}
